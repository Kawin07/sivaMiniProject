PORT=3000

# Shared secret expected in x-esp-trigger header from external website
ESP_TRIGGER=replace-with-strong-trigger-secret

# Trigger validity window in minutes after a successful external trigger
TRIGGER_ACTIVE_MINUTES=60

# Open-Meteo location for Poonamallee, Chennai
OPEN_METEO_LAT=13.0472
OPEN_METEO_LON=80.0945

# MQ135 digital threshold for HIGH/LOW alert state
MQ135_DIGITAL_THRESHOLD_PPM=420

# Optional: CORS override for your external trigger website
# TRIGGER_ALLOWED_ORIGIN=https://your-trigger-site.com
# Example for this deployment:
# TRIGGER_ALLOWED_ORIGIN=https://gleaming-eclair-f4aa84.netlify.app
